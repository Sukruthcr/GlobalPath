{
  "entities": {
    "Country": {
      "title": "Country",
      "description": "Country data including requirements, costs, and timelines",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "exams": { "type": "string" },
        "documents": { "type": "string" },
        "visa_steps": { "type": "string" },
        "financial_requirement": { "type": "string" },
        "work_rights": { "type": "string" },
        "pr_possibility": { "type": "string" },
        "timeline": { "type": "string" },
        "living_costs": { "type": "string" },
        "city_costs": { "type": "string" },
        "scholarships": { "type": "string" },
        "post_arrival_guide": { "type": "string" },
        "visa_prep": { "type": "string" },
        "part_time_info": { "type": "string" },
        "comparison_data": { "type": "string" }
      },
      "required": ["name"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin"],
          "description": "The user's role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created"
        }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "User's progress on checklists, timelines, and applications",
      "type": "object",
      "properties": {
        "checklist": {
          "type": "object",
          "description": "Map of country names to array of completed document names"
        },
        "timeline": {
          "type": "object",
          "description": "Map of country names to array of completed month indices"
        },
        "calculations": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Saved budget calculations"
        },
        "applications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "university": { "type": "string" },
              "course": { "type": "string" },
              "deadline": { "type": "string" },
              "status": { "type": "string" }
            }
          },
          "description": "User's university applications"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["checklist", "timeline", "calculations", "applications", "updatedAt"]
    }
  },
  "firestore": {
    "/countries/{countryId}": {
      "schema": { "$ref": "#/entities/Country" },
      "description": "Country data documents"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile documents"
    },
    "/users/{userId}/data/progress": {
      "schema": { "$ref": "#/entities/UserProgress" },
      "description": "User's progress data"
    }
  }
}
