# Environment Variables for Production Deployment
# Copy this file to .env and fill in your values

# JWT Secret for authentication (generate using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=your_jwt_secret_here

# Gemini API Key for AI features (get free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Set to production when deploying
NODE_ENV=production

